{
  "expo": {
    "name": "Literature",
    "slug": "literature-card-game",
    "version": "1.0.0",
    "scheme": "literature",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
  "plugins": [
    "expo-router",
    "expo-font",
    "expo-secure-store",
    "expo-dev-client"
  ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7519515a-5f31-49a8-bb52-b9459084f0d6"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/7519515a-5f31-49a8-bb52-b9459084f0d6"
    },
    "android": {
      "package": "com.literaturecardgame",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "literature",
              "host": "*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.literaturecardgame",
      "supportsTablet": true
    }
  }
}